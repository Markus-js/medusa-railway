# --- Connections (Railway will inject these from Postgres/Redis services) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/medusa
REDIS_URL=redis://default:password@localhost:6379?family=0

# --- Secrets (use Railway ${{secret(32)}} in production) ---
JWT_SECRET=replace-me
COOKIE_SECRET=replace-me

# --- CORS (point to your public Railway domain) ---
STORE_CORS=https://your-medusa.up.railway.app
ADMIN_CORS=https://your-medusa.up.railway.app
AUTH_CORS=https://your-medusa.up.railway.app

# --- Backend URL (for admin asset paths) ---
BACKEND_URL=https://your-medusa.up.railway.app
STOREFRONT_URL=https://your-cms-site.example.com

# --- File storage (required for Medusa Admin uploads, product export CSVs, etc.) ---
# Production/Railway: configure the S3-compatible bucket.
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=https://t3.storageapi.dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FILE_URL=https://your-cms-site.example.com/medusa-media
S3_FORCE_PATH_STYLE=true
S3_PREFIX=
S3_CACHE_CONTROL=public, max-age=31536000
S3_DOWNLOAD_FILE_DURATION=3600

# Local development fallback when S3_* is not configured.
LOCAL_FILE_BACKEND_URL=http://localhost:9000/static
LOCAL_FILE_UPLOAD_DIR=
LOCAL_FILE_PRIVATE_UPLOAD_DIR=

# --- Nexi Checkout / Nets Easy (optional payment provider) ---
# Set NEXI_CHECKOUT_SECRET_KEY to register provider id: pp_nexi-checkout_nexi
NEXI_CHECKOUT_ENV=test
NEXI_CHECKOUT_SECRET_KEY=
NEXI_CHECKOUT_BASE_URL=
NEXI_CHECKOUT_RETURN_URL=https://your-cms-site.example.com/shop/checkout/return
NEXI_CHECKOUT_CANCEL_URL=https://your-cms-site.example.com/shop/cart
NEXI_CHECKOUT_TERMS_URL=https://your-cms-site.example.com/vilkaar
NEXI_CHECKOUT_MERCHANT_TERMS_URL=
NEXI_CHECKOUT_WEBHOOK_URL=https://your-medusa.up.railway.app/hooks/payment/pp_nexi-checkout_nexi
NEXI_CHECKOUT_WEBHOOK_AUTHORIZATION=
NEXI_CHECKOUT_MERCHANT_NUMBER=
NEXI_CHECKOUT_COUNTRY_CODE=DNK
NEXI_CHECKOUT_AUTO_CAPTURE=false
NEXI_CHECKOUT_MERCHANT_HANDLES_CONSUMER_DATA=true
NEXI_CHECKOUT_PAYMENT_METHODS=
NEXI_CHECKOUT_WEBHOOK_EVENTS=

# --- Mode & port ---
MEDUSA_WORKER_MODE=shared
DISABLE_MEDUSA_ADMIN=false
PORT=9000
NODE_ENV=production

# --- Admin user (created on first boot, ignored thereafter) ---
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=change-me-on-first-login
